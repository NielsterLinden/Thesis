@article{collaborationObservationFourtopquarkProduction2023,
	title = {Observation of four-top-quark production in the multilepton final state with the {ATLAS} detector},
	volume = {83},
	issn = {1434-6052},
	url = {http://arxiv.org/abs/2303.15061},
	doi = {10.1140/epjc/s10052-023-11573-0},
	abstract = {This paper presents the observation of four-top-quark (\$t{\textbackslash}bar\{t\}t{\textbackslash}bar\{t\}\$) production in proton-proton collisions at the LHC. The analysis is performed using an integrated luminosity of 140 fb\${\textasciicircum}\{-1\}\$ at a centre-of-mass energy of 13 TeV collected using the ATLAS detector. Events containing two leptons with the same electric charge or at least three leptons (electrons or muons) are selected. Event kinematics are used to separate signal from background through a multivariate discriminant, and dedicated control regions are used to constrain the dominant backgrounds. The observed (expected) significance of the measured \$t{\textbackslash}bar\{t\}t{\textbackslash}bar\{t\}\$ signal with respect to the standard model (SM) background-only hypothesis is 6.1 (4.3) standard deviations. The \$t{\textbackslash}bar\{t\}t{\textbackslash}bar\{t\}\$ production cross section is measured to be \$22.5{\textasciicircum}\{+6.6\}\_\{-5.5\}\$ fb, consistent with the SM prediction of \$12.0 {\textbackslash}pm 2.4\$ fb within 1.8 standard deviations. Data are also used to set limits on the three-top-quark production cross section, being an irreducible background not measured previously, and to constrain the top-Higgs Yukawa coupling and effective field theory operator coefficients that affect \$t{\textbackslash}bar\{t\}t{\textbackslash}bar\{t\}\$ production.},
	number = {6},
	journal = {The European Physical Journal C},
	author = {Collaboration, ATLAS},
	month = jun,
	year = {2023},
	note = {arXiv:2303.15061 [hep-ex]},
	pages = {496}
}


