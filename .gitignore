# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
.cursor/

# Local papers / notes for agents (PDFs, exports, etc. — not tracked)
/agent_reference/*
!/agent_reference/README.md

# Agent / AI tool caches and local state (do not commit — large binaries + noise)
.agent-state/
.claude/
.cursorrules
docs/archive/
docs/AXES_AUDIT_LOG.md
docs/*.plan.md

# Python
__pycache__/
*.pyc
.venv/
.env
*.egg-info/

# Jupyter
.ipynb_checkpoints/
notebooks/

# Outputs
outputs/
multirun/
/wandb/
mlruns/

# Local configs
*.local.*
*.secrets.*
*.log

# Project-specific
00. Archive/

# HPC-specific
hpc/stoomboot/*.log
*.sub.backup
# Local W&B credentials (never commit)
hpc/stoomboot/.wandb_env
**/.wandb_env
**/.nfs*

# W&B patch traces: large CSVs (keep only unresolved/summary files if needed)
scripts/wandb/patch_traces/*.csv

# W&B: GPU eval shards + large one-off exports / pilot dumps (keep code + small schema only)
scripts/wandb/eval_pipeline/snapshots/
scripts/wandb/archive/
scripts/wandb/export/snapshots/
phase2_upload_log.csv

# Thesis results: only the frozen analysis CSV is tracked
thesis_results/*
!thesis_results/03_analysis_ready.csv
!thesis_results/04_cleaned_backfilled_analysis_ready.csv
!thesis_results/archive/*_04_cleaned_backfilled_analysis_ready.csv
