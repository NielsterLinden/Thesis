# Stage B: one Condor proc = one GPU = one Python process over a fixed row range.
#
# Evaluable manifest rows (sorted) use HALF-OPEN indices [ROW_START, ROW_START+ROW_COUNT).
#   Job A: ROW_START=0   ROW_COUNT=100  -> indices 0..99   -> shard .../shards/rows_00000_00100/
#   Job B: ROW_START=100 ROW_COUNT=100 -> indices 100..199 -> shard .../shards/rows_00100_00200/
# Pass ROW_START / ROW_COUNT on every condor_submit (no ProcId default — avoids duplicate slices).
#
# Condor .log = scheduler events; application progress is in stdout .out (see README).
# Do not name a macro MANIFEST — Condor reserves "manifest" (boolean) case-insensitively.
#
universe       = vanilla
executable     = hpc/stoomboot/thesis_inference.sh

EVAL_MANIFEST_CSV = /project/atlas/users/nterlind/Thesis-Code/wandb_cleanup/eval_pipeline/snapshots/2026-04-29_phase2/00_eval_manifest.csv
EVAL_PHASE_DIR    = /project/atlas/users/nterlind/Thesis-Code/wandb_cleanup/eval_pipeline/snapshots/2026-04-29_phase2
ROW_COUNT         = 100
QUEUE_COUNT       = 1
ROW_START         = 0

arguments      = --manifest $(EVAL_MANIFEST_CSV) --out-dir $(EVAL_PHASE_DIR) --row-start $(ROW_START) --row-count $(ROW_COUNT)

initialdir     = /project/atlas/users/nterlind/Thesis-Code

output         = /data/atlas/users/nterlind/logs/stdout/eval_b_$(ClusterId).$(ProcId).out
error          = /data/atlas/users/nterlind/logs/stderr/eval_b_$(ClusterId).$(ProcId).err
log            = /data/atlas/users/nterlind/logs/stdlog/eval_b_$(ClusterId).log

request_cpus   = 4
request_memory = 64GB
request_disk   = 64GB
request_gpus   = 1

+UseOS = "el9"
+JobCategory = "long"
should_transfer_files = NO
getenv         = True
stream_output  = True
stream_error   = True

environment = "APPTAINER_CACHEDIR=/data/atlas/users/nterlind/.apptainer_cache PYTHONUNBUFFERED=1"

queue $(QUEUE_COUNT)
