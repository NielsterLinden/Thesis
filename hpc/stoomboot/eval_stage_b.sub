# Stage B: one Condor proc = one GPU = one Python process = up to BATCH_SIZE runs per slice.
#
# Each job writes ONLY under: $(EVAL_PHASE_DIR)/shards/batch_<BATCH_SLICE zero-padded to 3 digits>
# (Python derives shard path from --out-dir + --batch-index). Safe to run many jobs in parallel.
#
# Submit one job per batch slice (typical BATCH_SIZE=100):
#   condor_submit hpc/stoomboot/eval_stage_b.sub EVAL_PHASE_DIR=... BATCH_SLICE=0
#   condor_submit hpc/stoomboot/eval_stage_b.sub EVAL_PHASE_DIR=... BATCH_SLICE=1
# Use QUEUE_COUNT>1 only if each proc must get a different ProcId as slice; otherwise prefer
# separate submits with BATCH_SLICE=0,1,... so each job has its own ClusterId / log files.
#
# Condor .log = scheduler events; application progress is in stdout .out (see README).
# Do not name a macro MANIFEST — Condor reserves "manifest" (boolean) case-insensitively.
#
universe       = vanilla
executable     = hpc/stoomboot/thesis_inference.sh

EVAL_MANIFEST_CSV = /project/atlas/users/nterlind/Thesis-Code/wandb_cleanup/eval_pipeline/snapshots/2026-04-29_phase2/00_eval_manifest.csv
EVAL_PHASE_DIR    = /project/atlas/users/nterlind/Thesis-Code/wandb_cleanup/eval_pipeline/snapshots/2026-04-29_phase2
BATCH_SIZE        = 100
QUEUE_COUNT       = 1
BATCH_SLICE       = $(ProcId)

arguments      = --manifest $(EVAL_MANIFEST_CSV) --out-dir $(EVAL_PHASE_DIR) --batch-index $(BATCH_SLICE) --batch-size $(BATCH_SIZE)

initialdir     = /project/atlas/users/nterlind/Thesis-Code

output         = /data/atlas/users/nterlind/logs/stdout/eval_b_$(ClusterId).$(ProcId).out
error          = /data/atlas/users/nterlind/logs/stderr/eval_b_$(ClusterId).$(ProcId).err
log            = /data/atlas/users/nterlind/logs/stdlog/eval_b_$(ClusterId).log

request_cpus   = 4
request_memory = 64GB
request_disk   = 64GB
request_gpus   = 1

+UseOS = "el9"
+JobCategory = "long"
should_transfer_files = NO
getenv         = True
stream_output  = True
stream_error   = True

environment = "APPTAINER_CACHEDIR=/data/atlas/users/nterlind/.apptainer_cache PYTHONUNBUFFERED=1"

queue $(QUEUE_COUNT)
